{
  "expo": {
    "name": "Bulp Fleet Manager",
    "slug": "bulp-fleet-manager-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android",
      "web",
      "windows"
    ],
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "bundleIdentifier": "com.yango.bulpfleetmanager",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.yango.bulpfleetmanager",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0f172a"
      }
    },
    "extra": {
      "apiBaseUrl": "http://localhost:4000/api",
      "eas": {
        "projectId": "9d934eb5-0230-45f4-b0c8-81532eb96a03"
      }
    }
  }
}
